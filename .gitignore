node_modules/
.env.local
.env
data/
.next/
dist/
next-env.d.ts
*.tsbuildinfo
.DS_Store

# Private user profile — résumé, preferences, narrative. All personal; never
# committed. Onboarding scaffolds these locally from in-code starter templates.
profile/

# Generated enrichment deep-dives at the repo ROOT (regenerable; scraped personal
# data). Anchored with a leading slash so these DON'T also ignore the app routes
# src/app/companies/ and src/app/people/ (a bare `companies/` matched those too).
/companies/
/people/

# Scratch space for one-off import maps, run logs, etc.
.scratch/

# Claude Code local config — tool/editor-specific, per-machine. The product's
# agent surface lives in `.claude/skills/` and IS committed; only local config
# is ignored here.
.claude/launch.json
.claude/settings.local.json
