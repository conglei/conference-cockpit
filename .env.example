# --- Database ---
# Local libSQL/SQLite file (default). Gitignored; rebuilt by `pnpm seed-demo`.
DATABASE_URL=data/conference.db
# Or point at a Turso cloud DB (shared by the agent + the deployed web app):
#   DATABASE_URL=libsql://<your-db>.turso.io
#   TURSO_AUTH_TOKEN=<db token>   # `turso db tokens create <db>` (use --read-only for the web)
# TURSO_AUTH_TOKEN=

# --- Web access (optional privacy gate) ---
# Set SITE_PASSWORD to require HTTP Basic Auth before the deployed UI renders.
# Unset = public (local dev / public demo). User defaults to "admin".
# SITE_USER=admin
# SITE_PASSWORD=

# --- Enrichment providers ---
# Selects the active EnrichmentProvider (config, not code). One of: fake | harvest | searchapi.
# Defaults to `fake` (offline, no keys, canned fixtures) when unset.
# `pnpm env:check` (and `pnpm onboard`) report which tiers are active and what's missing.
ENRICHMENT_PROVIDER=fake

# HarvestAPI — LinkedIn company/person profiles + company-employee rosters.
# Required for ENRICHMENT_PROVIDER=harvest.
# HARVESTAPI_KEY=

# SearchAPI (searchapi.io) — Google web search + Google Jobs.
# Required for ENRICHMENT_PROVIDER=searchapi and for the web-search resolution fallback tier.
# SEARCHAPI_KEY=
